---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="QR Code Component">
  <main class="bg-white rounded-2xl shadow-lg p-4 w-[320px] md:w-[375px] lg:w-[350px] text-center">
    <img src="/image-qr-code.png" alt="QR code" class="rounded-lg mb-6 w-full" />
    <h1 class="text-slate900 font-bold text-xl mb-4">
      Improve your front-end skills by building projects
    </h1>
    <p class="text-slate500 text-[15px] px-2 mb-6">
      Scan the QR code to visit Frontend Mentor and take your coding skills to the next level
    </p>
  </main>
</MainLayout>
